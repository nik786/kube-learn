# =========================================================
# BASE IMAGE
# =========================================================
FROM python:3.11-slim

# =========================================================
# WORKDIR
# =========================================================
WORKDIR /app

# =========================================================
# COPY FILES
# =========================================================
COPY . /app

# =========================================================
# INSTALL DEPENDENCIES
# =========================================================
RUN pip install --no-cache-dir -r requirements.txt

# =========================================================
# PYTHON SETTINGS
# =========================================================
ENV PYTHONUNBUFFERED=1

# =========================================================
# DEFAULT COMMAND
# =========================================================
CMD ["python", "run.py"]

